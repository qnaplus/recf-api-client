{
  "name": "recf-api-client",
  "version": "0.1.2",
  "author": "battlesqui_d",
  "description": "Typescript client library for the RECF Rest API",
  "license": "MIT",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "download_spec": "tsx scripts/fetch-openapi.ts",
    "generate": "pnpm download_spec && orval",
    "generate:clean": "orval --clean && pnpm generate",
    "clean": "rm -rf dist openapi.json",
    "build": "tsc",
    "build:clean": "pnpm clean && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "orval": "^8.19.0",
    "oxfmt": "^0.56.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "volta": {
    "node": "26.4.0",
    "pnpm": "11.9.0"
  },
  "packageManager": "pnpm@11.9.0",
  "keywords": [
    "recf",
    "robotics",
    "rest-client",
    "api-client",
    "typescript"
  ],
  "files": ["dist"]
}